        <mxCell id="data_platform" value="&lt;b&gt;Cloud / Data Platform&lt;/b&gt;&lt;br&gt;&lt;br&gt;Object storage, data warehouse, vector DB, graph DB, queue/event bus, compute orchestration." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="650" y="965" width="300" height="105" as="geometry" />
        </mxCell>

        <!-- Downstream systems -->
        <mxCell id="dashboard" value="&lt;b&gt;Dashboards &amp;amp; Investigation UI&lt;/b&gt;&lt;br&gt;&lt;br&gt;Explore entities, evidence trails, relationship graphs, timelines, and source provenance." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
