          <mxGeometry x="70" y="470" width="300" height="125" as="geometry" />
        </mxCell>
        <mxCell id="model_services" value="&lt;b&gt;AI / ML / NLP Model Services&lt;/b&gt;&lt;br&gt;&lt;br&gt;Embeddings, entity resolution, semantic search, translation, summarization, graph inference." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
