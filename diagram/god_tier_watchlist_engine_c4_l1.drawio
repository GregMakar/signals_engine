  <diagram id="god-tier-watchlist-engine-c4-l1" name="C4 Level 1 - System Context">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="C4 Level 1 — God-Tier Watchlist Engine: System Context" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="250" y="20" width="1100" height="40" as="geometry" />
        </mxCell>

        <!-- Central system -->
        <mxCell id="system" value="&lt;b&gt;God-Tier Watchlist Engine&lt;/b&gt;&lt;br&gt;&lt;br&gt;Continuously monitors predefined entities, detects weak signals, enriches evidence, scores relevance, discovers relationships, and outputs decision-grade intelligence." style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=16;fontStyle=0;align=center;verticalAlign=middle;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="560" y="410" width="480" height="210" as="geometry" />
        </mxCell>

        <!-- Humans -->
        <mxCell id="analyst" value="&lt;b&gt;Research Analyst / Operator&lt;/b&gt;&lt;br&gt;&lt;br&gt;Defines watchlists, reviews evidence, tunes concepts, validates alerts." style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="130" y="255" width="90" height="160" as="geometry" />
        </mxCell>
        <mxCell id="decision_maker" value="&lt;b&gt;Decision Maker&lt;/b&gt;&lt;br&gt;&lt;br&gt;Consumes reports, alerts, dashboards, and risk/opportunity briefs." style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="1370" y="255" width="90" height="160" as="geometry" />
        </mxCell>
        <mxCell id="engineer" value="&lt;b&gt;Data / ML Engineer&lt;/b&gt;&lt;br&gt;&lt;br&gt;Maintains pipelines, models, schemas, source connectors, and evaluation systems." style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="130" y="690" width="90" height="160" as="geometry" />
        </mxCell>

        <!-- External data providers -->
        <mxCell id="news_web" value="&lt;b&gt;News, Web &amp;amp; Social Sources&lt;/b&gt;&lt;br&gt;&lt;br&gt;GDELT, RSS, crawlers, social streams, forums, blogs, local media." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="330" y="130" width="270" height="120" as="geometry" />
        </mxCell>
        <mxCell id="filings" value="&lt;b&gt;Filings, Legal &amp;amp; Regulatory Sources&lt;/b&gt;&lt;br&gt;&lt;br&gt;SEC/EDGAR, SEDAR+, court records, sanctions, tenders, permits, customs." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="665" y="130" width="270" height="120" as="geometry" />
        </mxCell>
        <mxCell id="market_macro" value="&lt;b&gt;Market, Macro &amp;amp; Trade Data&lt;/b&gt;&lt;br&gt;&lt;br&gt;Prices, rates, FRED, World Bank, UN Comtrade, EIA, shipping, inventories." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1000" y="130" width="270" height="120" as="geometry" />
        </mxCell>
        <mxCell id="geo_sat" value="&lt;b&gt;Geospatial, Satellite &amp;amp; Physical-World Sensors&lt;/b&gt;&lt;br&gt;&lt;br&gt;AIS, ADS-B, weather, night lights, imagery, OSM, port/plant activity." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="330" y="800" width="290" height="120" as="geometry" />
        </mxCell>
        <mxCell id="academic_patent" value="&lt;b&gt;Academic, Patent &amp;amp; Technical Sources&lt;/b&gt;&lt;br&gt;&lt;br&gt;OpenAlex, Crossref, patents, GitHub, standards bodies, technical datasets." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="655" y="800" width="290" height="120" as="geometry" />
        </mxCell>
        <mxCell id="private_internal" value="&lt;b&gt;Private / Client Data Sources&lt;/b&gt;&lt;br&gt;&lt;br&gt;CRM, ERP, internal notes, proprietary datasets, analyst annotations, deal history." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
